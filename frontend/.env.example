# Credenciais do Supabase (Project Settings → API)
# Copie este arquivo para .env.local e preencha com os valores do seu projeto.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Username do bot de captura de templates (aparece nas instruções da aba
# Templates). Ex.: @MeuBotDeCaptura  — opcional.
VITE_CAPTURE_BOT_USERNAME=@SeuBotDeCaptura
